datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  ON_LEAVE
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  HALF_DAY
}

enum PaymentStatus {
  PAID
  PENDING
  PROCESSING
  FAILED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  passwordHash  String         @map("password_hash")
  role          Role           @default(EMPLOYEE)
  avatar        String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  notifications Notification[]
  activityLogs  ActivityLog[]
  employee      Employee?

  @@map("users")
}

model Employee {
  id            String         @id @default(uuid())
  employeeCode  String         @unique @map("employee_code")
  firstName     String         @map("first_name")
  lastName      String         @map("last_name")
  email         String         @unique
  phone         String?
  departmentId  String?        @map("department_id")
  department    Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designationId String?        @map("designation_id")
  designation   Designation?   @relation(fields: [designationId], references: [id], onDelete: SetNull)
  joiningDate   DateTime       @map("joining_date")
  salary        Float
  status        EmployeeStatus @default(ACTIVE)
  avatar        String?
  managerId     String?        @map("manager_id")
  manager       Employee?      @relation("ManagerToEmployee", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates  Employee[]     @relation("ManagerToEmployee")
  userId        String?        @unique @map("user_id")
  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendance    Attendance[]
  payrolls      Payroll[]
  leaves        Leave[]

  @@map("employees")
}

model Department {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  employees   Employee[]

  @@map("departments")
}

model Designation {
  id        String     @id @default(uuid())
  title     String     @unique
  level     Int        @default(1)
  employees Employee[]

  @@map("designations")
}

model Attendance {
  id               String           @id @default(uuid())
  employeeId       String           @map("employee_id")
  employee         Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  checkIn          DateTime         @map("check_in")
  checkOut         DateTime?        @map("check_out")
  totalHours       Float?           @map("total_hours")
  attendanceStatus AttendanceStatus @default(PRESENT) @map("attendance_status")
  date             DateTime         @db.Date

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@map("attendance")
}

model Payroll {
  id            String        @id @default(uuid())
  employeeId    String        @map("employee_id")
  employee      Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  baseSalary    Float         @map("base_salary")
  allowances    Float         @default(0)
  bonus         Float         @default(0)
  deductions    Float         @default(0)
  tax           Float         @default(0)
  netSalary     Float         @map("net_salary")
  payrollMonth  String        @map("payroll_month") // e.g. "2026-05"
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@unique([employeeId, payrollMonth])
  @@index([employeeId])
  @@index([payrollMonth])
  @@map("payrolls")
}

model Leave {
  id             String      @id @default(uuid())
  employeeId     String      @map("employee_id")
  employee       Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType      String      @map("leave_type") // e.g. "Casual", "Sick", "Maternity"
  startDate      DateTime    @map("start_date")
  endDate        DateTime    @map("end_date")
  reason         String?
  approvalStatus LeaveStatus @default(PENDING) @map("approval_status")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([employeeId])
  @@map("leaves")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}
